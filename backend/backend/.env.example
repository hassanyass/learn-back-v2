# Copy this file to `.env` and fill in real values.
# NEVER commit real secrets (API keys, DB passwords) to git.

# Database (required)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME

# JWT (required in production)
JWT_SECRET_KEY=change-me
JWT_ALGORITHM=HS256
JWT_EXP_MINUTES=60

# Supabase Storage
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# LLM providers
# Comma-separated key pools are supported.
GROQ_API_KEYS=
GROQ_MODEL=openai/gpt-oss-20b
GROQ_CHAT_COMPLETIONS_URL=https://api.groq.com/openai/v1/chat/completions

SECONDARY_LLM_API_KEYS=
SECONDARY_LLM_MODEL=openai/gpt-oss-20b
SECONDARY_CHAT_COMPLETIONS_URL=https://api.openai.com/v1/chat/completions

# ── Server / Deployment ──
PORT=8002
DEBUG=false
LOG_LEVEL=INFO
# Comma-separated list of allowed origins (use * for development)
CORS_ORIGINS=*
